rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is securely logged in via Firebase Auth
    function isAuthenticated() {
      return request.auth != null;
    }

    // 1. Profiles: A user can only view and edit their own profile document.
    match /profiles/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // 2. Playlists: A user can only view, edit, or delete playlists they created.
    match /playlists/{playlistId} {
      allow read, update, delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
    }

    // 3. Liked Songs: A user can only view, add, or remove their own liked songs.
    match /liked_songs/{songId} {
      allow read, update, delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
    }
  }
}
